generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role { SUPER_ADMIN SHOP_ADMIN STAFF }
enum Gender { MALE FEMALE OTHER }
enum FrameShape { ROUND OVAL RECTANGLE SQUARE CAT_EYE AVIATOR WAYFARER GEOMETRIC RIMLESS SEMI_RIMLESS }
enum OrderStatus { CREATED LENS_ORDERED GRINDING FITTING READY DELIVERED CANCELLED }
enum PaymentMethod { CASH UPI CARD MIXED }
enum PaymentStatus { PENDING PARTIAL PAID }
enum StockMovementType { IN OUT ADJUSTMENT RETURN }
enum LensType { SINGLE_VISION BIFOCAL PROGRESSIVE READING }

model Store {
  id             String   @id @default(uuid())
  name           String
  address        String?
  phone          String?
  email          String?
  gstNumber      String?
  taxRate        Float    @default(18)
  invoicePrefix  String   @default("INV")
  invoiceCounter Int      @default(1000)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  users       User[]
  customers   Customer[]
  frames      Frame[]
  lenses      Lens[]
  orders      Order[]
  accessories Accessory[]
  suppliers   Supplier[]
  purchases   Purchase[]
  @@map("stores")
}

model User {
  id           String    @id @default(uuid())
  storeId      String
  name         String
  email        String    @unique
  phone        String?
  passwordHash String
  role         Role      @default(STAFF)
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  store  Store   @relation(fields: [storeId], references: [id])
  orders Order[]
  @@index([storeId])
  @@index([email])
  @@map("users")
}

model Customer {
  id          String    @id @default(uuid())
  storeId     String
  name        String
  phone       String
  email       String?
  address     String?
  gender      Gender?
  age         Int?
  dateOfBirth DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  store         Store          @relation(fields: [storeId], references: [id])
  prescriptions Prescription[]
  orders        Order[]
  @@index([storeId])
  @@index([phone])
  @@map("customers")
}

model Prescription {
  id         String   @id @default(uuid())
  customerId String
  doctorName String?
  date       DateTime @default(now())
  rightSph   Float?
  rightCyl   Float?
  rightAxis  Int?
  rightAdd   Float?
  rightPd    Float?
  leftSph    Float?
  leftCyl    Float?
  leftAxis   Int?
  leftAdd    Float?
  leftPd     Float?
  pd         Float?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer Customer @relation(fields: [customerId], references: [id])
  orders   Order[]
  @@index([customerId])
  @@map("prescriptions")
}

model Frame {
  id            String     @id @default(uuid())
  storeId       String
  frameCode     String
  brand         String
  model         String?
  shape         FrameShape @default(RECTANGLE)
  color         String?
  material      String?
  purchasePrice Float      @default(0)
  sellingPrice  Float
  stockQty      Int        @default(0)
  lowStockAlert Int        @default(5)
  barcode       String?
  isActive      Boolean    @default(true)
  supplierId    String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  store      Store           @relation(fields: [storeId], references: [id])
  supplier   Supplier?       @relation(fields: [supplierId], references: [id])
  orderItems OrderItem[]
  stockLogs  StockMovement[]
  @@index([storeId])
  @@index([brand])
  @@map("frames")
}

model Lens {
  id            String   @id @default(uuid())
  storeId       String
  name          String
  lensType      LensType @default(SINGLE_VISION)
  lensIndex     String   @default("1.56")
  coating       String[]
  brand         String?
  purchasePrice Float    @default(0)
  sellingPrice  Float
  stockQty      Int      @default(100)
  lowStockAlert Int      @default(10)
  isActive      Boolean  @default(true)
  supplierId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  store      Store           @relation(fields: [storeId], references: [id])
  supplier   Supplier?       @relation(fields: [supplierId], references: [id])
  orderItems OrderItem[]
  stockLogs  StockMovement[]
  @@index([storeId])
  @@map("lenses")
}

model Accessory {
  id            String   @id @default(uuid())
  storeId       String
  name          String
  category      String
  purchasePrice Float    @default(0)
  sellingPrice  Float
  stockQty      Int      @default(0)
  lowStockAlert Int      @default(5)
  barcode       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  store      Store           @relation(fields: [storeId], references: [id])
  orderItems OrderItem[]
  stockLogs  StockMovement[]
  @@index([storeId])
  @@map("accessories")
}

model Order {
  id             String        @id @default(uuid())
  storeId        String
  orderNumber    String        @unique
  customerId     String
  prescriptionId String?
  staffId        String
  notes          String?
  subtotal       Float
  discountAmount Float         @default(0)
  taxAmount      Float         @default(0)
  taxPct         Float         @default(18)
  totalAmount    Float
  advanceAmount  Float         @default(0)
  balanceAmount  Float
  status         OrderStatus   @default(CREATED)
  deliveryDate   DateTime?
  deliveredAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  paymentStatus  PaymentStatus @default(PENDING)
  paymentMethod  PaymentMethod @default(CASH)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  store        Store            @relation(fields: [storeId], references: [id])
  customer     Customer         @relation(fields: [customerId], references: [id])
  prescription Prescription?    @relation(fields: [prescriptionId], references: [id])
  staff        User             @relation(fields: [staffId], references: [id])
  items        OrderItem[]
  payments     Payment[]
  statusLogs   OrderStatusLog[]
  @@index([storeId])
  @@index([customerId])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  itemType    String
  frameId     String?
  lensId      String?
  accessoryId String?
  name        String
  quantity    Int     @default(1)
  unitPrice   Float
  totalPrice  Float
  order     Order      @relation(fields: [orderId], references: [id])
  frame     Frame?     @relation(fields: [frameId], references: [id])
  lens      Lens?      @relation(fields: [lensId], references: [id])
  accessory Accessory? @relation(fields: [accessoryId], references: [id])
  @@index([orderId])
  @@map("order_items")
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String
  amount    Float
  method    PaymentMethod
  reference String?
  note      String?
  paidAt    DateTime      @default(now())
  order Order @relation(fields: [orderId], references: [id])
  @@index([orderId])
  @@map("payments")
}

model OrderStatusLog {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  note      String?
  changedAt DateTime    @default(now())
  order Order @relation(fields: [orderId], references: [id])
  @@index([orderId])
  @@map("order_status_logs")
}

model StockMovement {
  id          String            @id @default(uuid())
  storeId     String
  frameId     String?
  lensId      String?
  accessoryId String?
  type        StockMovementType
  quantity    Int
  beforeQty   Int
  afterQty    Int
  reason      String?
  createdAt   DateTime          @default(now())
  frame     Frame?     @relation(fields: [frameId], references: [id])
  lens      Lens?      @relation(fields: [lensId], references: [id])
  accessory Accessory? @relation(fields: [accessoryId], references: [id])
  @@index([storeId])
  @@map("stock_movements")
}

model Supplier {
  id        String   @id @default(uuid())
  storeId   String
  name      String
  phone     String?
  email     String?
  address   String?
  gstNumber String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id])
  frames    Frame[]
  lenses    Lens[]
  purchases Purchase[]
  @@index([storeId])
  @@map("suppliers")
}

model Purchase {
  id            String   @id @default(uuid())
  storeId       String
  supplierId    String
  invoiceNumber String?
  totalAmount   Float
  notes         String?
  purchasedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  store    Store          @relation(fields: [storeId], references: [id])
  supplier Supplier       @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]
  @@index([storeId])
  @@map("purchases")
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  itemType   String
  itemId     String
  itemName   String
  quantity   Int
  unitCost   Float
  totalCost  Float
  purchase Purchase @relation(fields: [purchaseId], references: [id])
  @@index([purchaseId])
  @@map("purchase_items")
}
